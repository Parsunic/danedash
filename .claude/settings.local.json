{
  "permissions": {
    "allow": [
      "Bash(netlify --version)",
      "Bash(netlify status *)",
      "Bash(git init *)",
      "Bash(git remote *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git commit -m \"*)",
      "Bash(git branch *)",
      "Bash(git push *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd C:/Projects/UltraDash && git add -A && git commit -m \"Auto-deploy: update dashboard\" && git push",
            "shell": "bash",
            "statusMessage": "Pushing to GitHub…",
            "async": true
          }
        ]
      }
    ]
  }
}
