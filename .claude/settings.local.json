{
  "permissions": {
    "allow": [
      "Bash(netlify --version)",
      "Bash(netlify status *)",
      "Bash(git init *)",
      "Bash(git remote *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git commit -m \"*)",
      "Bash(git branch *)",
      "Bash(git push *)",
      "Bash(git -C \"C:/Projects/UltraDash\" log --oneline -5)",
      "Bash(git show *)",
      "Bash(npm run *)",
      "Bash(Get-ChildItem -Path \"c:\\\\Projects\\\\UltraDash\" -Recurse -Force)",
      "Bash(Select-Object FullName, PSIsContainer)",
      "Bash(Sort-Object FullName)",
      "Bash(Format-List)",
      "Bash(npx vite *)",
      "Bash(curl -s http://localhost:5199/)",
      "Bash(which chromium-browser chromium google-chrome 2>/dev/null || echo \"no chrome found\" *)",
      "Read(//usr/**)",
      "Bash(npx playwright *)",
      "Bash(node -e \"require\\('playwright'\\)\")",
      "Bash(npm install *)",
      "Bash(node -e \"const {chromium} = require\\('playwright'\\); console.log\\('ok'\\)\")",
      "Bash(node -e ' *)",
      "PowerShell(node node_modules/playwright/cli.js install chromium 2>&1)",
      "Bash(Get-ChildItem -Path \"c:\\\\Projects\\\\UltraDash\\\\src\\\\modules\" -Recurse -File -Filter \"*.tsx\" -o \"*.ts\" -o \"*.jsx\" -o \"*.js\")",
      "Bash(Select-Object -ExpandProperty FullName)",
      "Bash(cat >> *)",
      "Bash(python3 -c ' *)",
      "Bash(npm -v)",
      "PowerShell(node -v)",
      "PowerShell(npm -v)",
      "PowerShell(\"token=[$env:SUPABASE_ACCESS_TOKEN]\")",
      "Bash(git reset *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd C:/Projects/UltraDash && git add -A && git commit -m \"Auto-deploy: update dashboard\" && git push",
            "shell": "bash",
            "statusMessage": "Pushing to GitHub…",
            "async": true
          }
        ]
      }
    ]
  }
}
